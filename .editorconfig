# .editorconfig
# https://editorconfig.org
# drowsy-unity (Unity 6 / C# プロジェクト) のフォーマット規約
root = true

# ───────────────────────────────────────────────
# 共通
# ───────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

# ───────────────────────────────────────────────
# C#
# ───────────────────────────────────────────────
[*.cs]
indent_size = 4

# using ディレクティブの並び順・配置
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:suggestion

# var の使用方針
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:silent

# expression-bodied メンバー
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# 中括弧スタイル
csharp_new_line_before_open_brace = all
csharp_prefer_braces = true:suggestion

# this. を付けない
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# null / readonly / simplified using
dotnet_style_readonly_field = true:suggestion
csharp_style_throw_expression = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
csharp_prefer_simple_using_statement = true:suggestion

# ─── 命名規則 ───
# private フィールド: _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_case

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

# const: PascalCase
dotnet_naming_rule.constants_pascal.severity = warning
dotnet_naming_rule.constants_pascal.symbols = constants
dotnet_naming_rule.constants_pascal.style = pascal_case

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const

dotnet_naming_style.pascal_case.capitalization = pascal_case

# public / internal / protected メンバー: PascalCase
dotnet_naming_rule.public_members_pascal.severity = warning
dotnet_naming_rule.public_members_pascal.symbols = public_members
dotnet_naming_rule.public_members_pascal.style = pascal_case

dotnet_naming_symbols.public_members.applicable_kinds = property,method,event,field
dotnet_naming_symbols.public_members.applicable_accessibilities = public,internal,protected

# ─── Roslyn Analyzer severity 制御 ───
# Microsoft.CodeAnalysis.NetAnalyzers (CA-prefix) と Microsoft.Unity.Analyzers (UNT-prefix)
# Roslynator.Analyzers (RCS-prefix) も含む
# C# コンパイラ警告 (CS-prefix) も含めて重要ルールを error レベルに引き上げる

# Null 安全 (C# nullable reference types)
# 注: 本プロジェクトは ADR-0015 で NRT(Nullable Reference Types)を非採用と決定済。
# `#nullable enable` をどのファイルにも書いていないため、以下の CS8xxx は事実上発火しない安全網。
# ADR-0015 が将来 Superseded by ... で覆って NRT 採用に転じた際に、即時 error 化される設定として残置する。
dotnet_diagnostic.CS8600.severity = error    # null リテラルを非 nullable 型に代入
dotnet_diagnostic.CS8602.severity = error    # null 参照の可能性がある参照の逆参照
dotnet_diagnostic.CS8603.severity = error    # null 参照の可能性がある戻り値
dotnet_diagnostic.CS8618.severity = error    # コンストラクターで非 nullable フィールド未初期化

# Unity 固有 (Microsoft.Unity.Analyzers)
dotnet_diagnostic.UNT0001.severity = warning # 空の Unity メッセージ
dotnet_diagnostic.UNT0006.severity = error   # コルーチンの不正な戻り型
dotnet_diagnostic.UNT0013.severity = warning # 無効または重複した SerializeField 属性
dotnet_diagnostic.UNT0014.severity = warning # GetComponent の不正な型引数
dotnet_diagnostic.UNT0017.severity = warning # SetPixels で計算可能な引数

# 品質 (Microsoft.CodeAnalysis.NetAnalyzers)
dotnet_diagnostic.CA1822.severity = warning  # static にできるメソッド
dotnet_diagnostic.CA2000.severity = warning  # IDisposable のスコープ外リーク
dotnet_diagnostic.CA1052.severity = silent   # static class に関する警告は Unity の MonoBehaviour パターンで頻出のため silent

# 命名規則 (Microsoft.CodeAnalysis.NetAnalyzers の CA17xx は本ファイルの dotnet_naming_rule で代替)
dotnet_diagnostic.CA1707.severity = silent   # 識別子のアンダースコアを許可 (private field _camelCase との整合)
dotnet_diagnostic.CA1716.severity = silent   # 言語予約語との衝突警告は本プロジェクトの英語命名で十分回避

# 定数管理 (docs/architecture/constants-management.md / CLAUDE.md「9. 定数管理方針」)
dotnet_diagnostic.CA1802.severity = warning  # static readonly のリテラル → const 化推奨 (マジックナンバー削減の一環)

# ─── Roslynator.Analyzers (RCS-prefix) ───
# ADR-0013 で導入。Roslynator は 200+ ルールを提供するが、既存コードへの影響を制御するため
# baseline はカテゴリ全体を silent にし、後続 PR で個別ルールを段階的に warning/error へ昇格する。
# (段階的有効化は docs/todo.md「Roslynator RCS ルールの段階的有効化」で追跡)
dotnet_analyzer_diagnostic.category-roslynator.severity = silent

# 第 1 弾(2026-05-13): 影響範囲の小さい代表的なコードシンプリフィケーション / 衛生規則を warning 化
dotnet_diagnostic.RCS1018.severity = warning  # アクセス修飾子の明示(`private` を省略しない)
dotnet_diagnostic.RCS1049.severity = warning  # 冗長な boolean 比較を簡略化(`x == true` → `x`)
dotnet_diagnostic.RCS1163.severity = warning  # 未使用パラメータ
dotnet_diagnostic.RCS1170.severity = warning  # read-only auto-property 化(Immutability 方針整合)
# 第 2 弾(2026-05-16): フォーマット / 冗長性除去系で既存コード違反 0 件のものを warning 化
dotnet_diagnostic.RCS1036.severity = warning  # 連続する空行を削除(冗長な空行)
dotnet_diagnostic.RCS1037.severity = warning  # 末尾空白の削除(.editorconfig `trim_trailing_whitespace` と整合)
dotnet_diagnostic.RCS1097.severity = warning  # 冗長な ToString() 呼び出しの削除
# 第 3 弾(2026-05-17): 文字列 / enum の衛生規則
# - RCS1192 / RCS1234: 既存コード違反 0 件で導入
# - RCS1214: 既存違反 3 箇所(EffectInterpreter.cs L106/L107/L148)を本 PR 同時修正で導入
dotnet_diagnostic.RCS1192.severity = warning  # 不要な逐語的文字列リテラル(@"abc" → "abc")
dotnet_diagnostic.RCS1214.severity = warning  # 不要な文字列補間($"abc" → "abc")
dotnet_diagnostic.RCS1234.severity = warning  # enum の重複値検出
# 第 4 弾(2026-05-17): const にできるローカル変数を明示化
# - RCS1118: 既存違反 15+ 箇所(テスト中心の JSON string 等)を本 PR 同時修正で導入
dotnet_diagnostic.RCS1118.severity = warning  # const にできるローカル変数(コンパイル時定数の明示化)
# 検討候補だが第 1 弾から除外したルール(docs/todo.md TODO #7 で継続追跡):
# - RCS1213(未使用 private メンバー): Unity のライフサイクルメソッド(`OnEnable` / `OnValidate` /
#   `Awake` / `Start` / `Update` 等は Unity Engine が reflection で呼ぶ)を Roslynator が
#   認識せず false positive を起こす。Unity ファイルで頻発するため別 PR で抑制方法
#   (`[UsedImplicitly]` 属性付与 / Unity ライフサイクル名単位の suppression 等)と合わせて評価する

# ───────────────────────────────────────────────
# 設定ファイル
# ───────────────────────────────────────────────
[*.{json,jsonc,json5}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{xml,uxml,uss,tss}]
indent_size = 2

# ───────────────────────────────────────────────
# Markdown
# ───────────────────────────────────────────────
[*.{md,markdown}]
trim_trailing_whitespace = false

# ───────────────────────────────────────────────
# Unity YAML / シリアライズアセット — フォーマッタの介入を防ぐ
# (.asmdef / .asmref / .inputactions / .shadergraph / .shadersubgraph は
#  .gitattributes で unity-json として扱うため上記 JSON ルールを適用する)
# ───────────────────────────────────────────────
[*.{unity,prefab,asset,mat,anim,controller,playable,mask,meta}]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false
insert_final_newline = false
